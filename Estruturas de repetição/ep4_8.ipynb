      "source": [
        "def calcular_pi(n):\n",
        "    pi = 0\n",
        "    for i in range (n):\n",
        "      denominador = ((2 * i) + 1)\n",
        "      if i % 2 == 0:\n",
        "        pi += 1/denominador\n",
        "      else:\n",
        "        pi -= 1/denominador\n",
        "    resultado = pi * 4\n",
        "    return(resultado)"
      ]
    }
  ]
}