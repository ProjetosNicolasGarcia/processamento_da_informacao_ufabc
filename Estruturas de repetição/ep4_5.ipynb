      "source": [
        "#Declarando a variável que armazena o valor \"n\"\n",
        "\n",
        "valor = int(input())\n",
        "\n",
        "\n",
        "#Construindo a função que gera a pirâmide:\n",
        "\n",
        "def construindo_piramide(valor):\n",
        "  for linha in range(1, valor+1):\n",
        "    print((str(linha) + \" \") * linha)\n",
        "\n",
        "#Montando a saída do programa:\n",
        "\n",
        "construindo_piramide(valor)\n"
      ]
    }
