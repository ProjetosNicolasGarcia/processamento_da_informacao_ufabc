        "#declarando a variável:\n",
        "\n",
        "n = int(input())\n",
        "\n",
        "#configurando método para realizar a decomposição:\n",
        "\n",
        "def decompondo_numeros(n):\n",
        "  while n > 0:\n",
        "    digito = n % 10\n",
        "    print(digito)\n",
        "    n = n // 10\n",
        "\n",
        "#chamando a saída do programa\n",
        "decompondo_numeros(n)\n",
        "\n",
